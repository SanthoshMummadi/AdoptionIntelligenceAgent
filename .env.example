# Copy to `.env` and fill in real values. Do not commit `.env`.

# Set to 1 to skip server.py startup env checks (pytest / python tests/*.py skip automatically)
# PRODUCT_ADOPTION_SKIP_ENV_VALIDATION=1

# Snowflake — query / connection timeouts (seconds)
SNOWFLAKE_STATEMENT_TIMEOUT=30
# Slower views: optional per-path overrides (seconds)
SNOWFLAKE_HEALTH_STATEMENT_TIMEOUT=90
SNOWFLAKE_USAGE_PRECHECK_TIMEOUT=20
SNOWFLAKE_USAGE_CIDM_TIMEOUT=45
# Multi-account usage: 0 = merge per-account CIDM only (default; lighter queries).
#SNOWFLAKE_USAGE_HIERARCHY_USE_AGGREGATE=0
# Multi-account GROUP BY timeout (only when USE_AGGREGATE=1); default max(120, USAGE_CIDM_TIMEOUT)
#SNOWFLAKE_USAGE_CIDM_HIERARCHY_TIMEOUT=120
# Wide attrition pull (get_account_attrition_all); default 90s if unset
#SNOWFLAKE_ATTRITION_STATEMENT_TIMEOUT=90
# Global CIDM MAX(SNAPSHOT_DT) for hierarchy usage (default 120s in code if unset)
#SNOWFLAKE_USAGE_MAX_SNAPSHOT_TIMEOUT=120
#SNOWFLAKE_USAGE_MAX_SNAPSHOT_ATTEMPTS=3
#SNOWFLAKE_USAGE_MAX_SNAPSHOT_RETRY_SLEEP_S=4
# After repeated 57014 failures, skip MAX for this many seconds (per process)
#SNOWFLAKE_CIDM_SNAPSHOT_BACKOFF_S=120
# Optional: pin snapshot date (YYYY-MM-DD) to skip MAX entirely during unstable runs
#SNOWFLAKE_CIDM_SNAPSHOT_DT=2025-03-15
SNOWFLAKE_NETWORK_TIMEOUT=30
SNOWFLAKE_LOGIN_TIMEOUT=60

# Snowflake connection pool — default max 8 in code if unset.
# Rule of thumb: pool_size >= GM_REVIEW_MAX_CONCURRENT (default 3) × 4 Snowflake tasks per account.
# Default cold-start connections: min(4, pool_size). Override with SNOWFLAKE_POOL_INITIAL_SIZE.
SNOWFLAKE_POOL_SIZE=16

# GM Review / enrich_account thread waits (seconds) — raise if you see TimeoutError in logs
#GM_REVIEW_ENRICH_TIMEOUT=120
#GM_REVIEW_ATTRITION_ALL_TIMEOUT=60
# Parallel GM Review accounts (default 1 = sequential, gentle on Snowflake). Max 12.
#GM_REVIEW_MAX_CONCURRENT=1
#SNOWFLAKE_ENRICH_HEALTH_WAIT_S=90
#SNOWFLAKE_ENRICH_USAGE_WAIT_S=120
#SNOWFLAKE_ENRICH_RENEWAL_WAIT_S=45
#SNOWFLAKE_ENRICH_ARI_WAIT_S=45

# Salesforce — max concurrent REST calls across the process (GM Review + other callers)
SF_MAX_CONCURRENT=10

# LLM Gateway — circuit breaker (transient failures increment counter; skip LLM while open)
LLM_CIRCUIT_THRESHOLD=3   # failures before circuit opens
LLM_CIRCUIT_COOLDOWN=300  # seconds in degraded mode (5 min)
# Risk analysis uses one combined prompt (risk notes + recommendations) per account
# to save ~1 gateway round-trip (~4–5s/account). Model is LLM_MODEL in .env when set.

# LLM Gateway URL (default is internal sfproxy devx endpoint)
# LLM_GATEWAY_URL=https://.../v1/chat/completions

# TLS: internal Salesforce LLM proxy uses corporate CA (not in certifi).
# Option A — point to corporate / system CA bundle (recommended):
# LLM_GATEWAY_CA_BUNDLE=/etc/ssl/certs/ca-certificates.crt
# LLM_GATEWAY_CA_BUNDLE=/usr/local/share/ca-certificates/sfdc-ca.crt
# Option B — if no bundle, internal hosts auto-disable verify; optional explicit flag:
# LLM_GATEWAY_VERIFY=false

# Daily pulse configuration
PULSE_FREQUENCY=daily
PULSE_SCHEDULE_TIME=09:00
PULSE_CHANNEL=
